# WSL-first approval surface
# Active rules should reflect the Linux runtime, not Windows-native shells.

prefix_rule(pattern=["bash"], decision="allow")
prefix_rule(pattern=["python3"], decision="allow")
prefix_rule(pattern=["git"], decision="allow")
prefix_rule(pattern=["docker"], decision="allow")
prefix_rule(pattern=["npm"], decision="allow")
prefix_rule(pattern=["npx"], decision="allow")
prefix_rule(pattern=["rtk"], decision="allow")
prefix_rule(pattern=["ollama"], decision="allow")
