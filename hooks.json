{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File hooks/session-start.ps1",
            "statusMessage": "Loading planning context"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File hooks/user-prompt-submit.ps1"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "py -3 hooks/pre_tool_use.py || python hooks/pre_tool_use.py",
            "statusMessage": "Checking plan before Bash"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "py -3 hooks/post_tool_use.py || python hooks/post_tool_use.py",
            "statusMessage": "Reviewing Bash against plan"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 hooks/stop.py || python hooks/stop.py",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
